import pandas as pd
import pymysql
from sqlalchemy import create_engine
import numpy as np

engine = create_engine('mysql+pymysql://root:@127.0.0.1:3306/stock_db')
prices = pd.read_sql("""
SELECT * FROM sample_etf;
""", con=engine, index_col='Date')
rets = prices.pct_change(1).dropna()


## 포트폴리오 객체 생성
import riskfolio as rp

pd.DataFrame.append = pd.DataFrame._append

port = rp.Portfolio(returns=rets)

## 입력값 계산
method_mu = 'hist' # 역사적 데이터를 바탕으로 기대 수익률 산정
method_cov = 'hist' # 역사적 데이터를 바탕으로 분산-공분산 행렬 추정

## 객체에 수익률 및 분산-공분산 입력
port.assets_stats(method_mu=method_mu, method_cov=method_cov)

model ='Classic'
rm = 'MV'
obj = 'MinRisk' # 목적함수. MinRisk(최소분산), MaxRet(최대수익률), Utility(효용) or Sharpe(사프지수)
hist = True
rf = 0
l = 0

w = port.optimization(model=model, rm=rm, obj=obj, rf=rf, l=l, hist=hist)

round(w.T, 4)

import matplotlib.pyplot as plt

ax = rp.plot_bar(w=w, title='Portfolio', kind='h', ax=None)
plt.show()

# 구석해(Corner Solution) 발생 : 변동성이 가장 낮은 종목에 대부분의 비중이 투자됨
# 각종 제약 조건을 추가해야 함 

